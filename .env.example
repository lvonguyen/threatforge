# ThreatForge — Local Development Environment
# Copy to .env and fill in values before running: docker compose up

# Required
REDIS_PASSWORD=change-me-strong-password
THREATFORGE_API_KEY=change-me-api-key

# Threat Intel API Keys (optional — disabled when empty)
MISP_API_KEY=
OTX_API_KEY=
VIRUSTOTAL_API_KEY=
GREYNOISE_API_KEY=
ABUSEIPDB_API_KEY=

# Splunk HEC Tokens (optional)
SPLUNK_HEC_TOKEN_INBOUND=
SPLUNK_HEC_TOKEN_OUTBOUND=
